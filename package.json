{
  "name": "pi-ocarina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare:agent-host": "bun install --cwd agent-host --frozen-lockfile --production",
    "package:macos": "bun run prepare:agent-host && tauri build --bundles app",
    "test:packaged": "bash scripts/test-packaged-macos.sh",
    "audit:parity": "node_modules/node/bin/node scripts/audit-parity.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "check": "bun run lint && bun run typecheck && bun run build && bun run rust:fmt && bun run rust:lint && bun run rust:test && bun run rust:build",
    "rust:build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "rust:fmt": "cargo fmt --check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "bun run test:e2e",
    "test:e2e": "bun run build:e2e && wdio run wdio.conf.js",
    "build:e2e": "VITE_E2E=true tauri build --debug --no-bundle --config src-tauri/tauri.e2e.conf.json",
    "tauri": "tauri",
    "agent-host": "node_modules/node/bin/node agent-host/src/host.js",
    "test:agent-host": "node_modules/node/bin/node --test agent-host/test/*.test.js",
    "test:design-system": "node_modules/node/bin/node --test src/shared/ui/matrix.test.js"
    ,"test:frontend-unit": "node_modules/node/bin/node --test src/features/threads/coalesced-task.test.js src/shared/ui/matrix.test.js"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@mariozechner/pi-coding-agent": "0.73.1",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "node": "20.19.5",
    "pixelarticons": "^2.2.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@wdio/cli": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "eslint": "10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "webdriverio": "9.29.1"
  }
}
