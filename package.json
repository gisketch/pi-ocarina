{
  "name": "pi-ocarina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "scripts": {
    "cosmos": "cosmos",
    "cosmos:export": "cosmos-export",
    "dev": "bun run build:agent-host && vite",
    "build": "bun run build:agent-host && vite build",
    "build:agent-host": "tsc -p agent-host/tsconfig.build.json",
    "prepare:agent-host": "bun install --cwd agent-host --frozen-lockfile --production && bun run build:agent-host",
    "package:macos": "bun run prepare:agent-host && tauri build --bundles app",
    "test:packaged": "bash scripts/test-packaged-macos.sh",
    "audit:parity": "tsx scripts/audit-parity.mts",
    "lint": "eslint .",
    "typecheck:frontend": "tsc -p tsconfig.json",
    "typecheck:tools": "tsc -p tsconfig.tools.json",
    "typecheck:agent-host": "tsc -p agent-host/tsconfig.json",
    "typecheck": "bun run typecheck:frontend && bun run typecheck:tools && bun run typecheck:agent-host",
    "check": "bun run lint && bun run typecheck && bun run test:frontend-unit && bun run test:agent-host && bun run build && bun run rust:fmt && bun run rust:lint && bun run rust:test && bun run rust:build",
    "rust:build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "rust:fmt": "cargo fmt --check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "bun run test:e2e",
    "test:e2e": "bun run build:e2e && wdio run wdio.conf.ts",
    "build:e2e": "VITE_E2E=true tauri build --debug --no-bundle --config src-tauri/tauri.e2e.conf.json",
    "tauri": "tauri",
    "agent-host": "bun run build:agent-host && agent-host/node_modules/node/bin/node agent-host/dist/host.js",
    "test:agent-host": "tsx --test agent-host/test/*.test.ts",
    "test:design-system": "tsx --test src/shared/ui/matrix.test.ts",
    "test:frontend-unit": "tsx --test src/features/**/*.test.ts src/shared/**/*.test.ts"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pixelarticons": "^2.2.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@wdio/cli": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "eslint": "10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jiti": "^2.7.0",
    "react-cosmos": "^7.3.0",
    "react-cosmos-plugin-vite": "^7.3.0",
    "tailwindcss": "4.3.2",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "webdriverio": "9.29.1"
  }
}
