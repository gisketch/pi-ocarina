{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Ocarina",
  "version": "0.1.0",
  "identifier": "tech.cmdblock.pi-ocarina",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Pi Ocarina",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 14, "y": 25 },
        "hiddenTitle": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../agent-host/dist": "agent-host/dist",
      "../agent-host/node_modules": "agent-host/node_modules",
      "../agent-host/package.json": "agent-host/package.json"
    }
  }
}
